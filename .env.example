# K8s GraphRAG Chatbot - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# OpenAI API Key (required)
# Used for: intent extraction (gpt-4o-mini), YAML generation (gpt-4o-mini),
#           and embedding generation (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Neo4j connection (required)
# For local dev: neo4j://localhost:7687
# For Neo4j Aura (cloud): neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-aura-password>

# Environment tag (optional)
ENVIRONMENT=production
